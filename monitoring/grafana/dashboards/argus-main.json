{
  "uid": "argus-main",
  "title": "Argus AI — Performance",
  "description": "Dashboard principal de observabilidade do Argus AI",
  "tags": ["argus", "performance"],
  "timezone": "America/Sao_Paulo",
  "refresh": "30s",
  "schemaVersion": 39,
  "time": { "from": "now-24h", "to": "now" },
  "graphTooltip": 1,
  "panels": [
    {
      "id": 50, "type": "row", "title": "🚨 Saúde do Sistema",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 51, "type": "stat", "title": "🚨 Alertas Firing",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "targets": [{ "datasource": { "uid": "prometheus-argus" }, "refId": "A",
        "expr": "grafana_alerting_alerts{state=\"alerting\"}" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background",
        "graphMode": "none", "orientation": "auto", "textMode": "auto", "justifyMode": "center" },
      "fieldConfig": { "defaults": { "unit": "short",
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "red", "value": 1 }
        ]}}}
    },
    {
      "id": 52, "type": "stat", "title": "✅ Saudáveis",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "targets": [{ "datasource": { "uid": "prometheus-argus" }, "refId": "A",
        "expr": "grafana_alerting_alerts{state=\"normal\"}" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background",
        "graphMode": "none", "orientation": "auto", "textMode": "auto", "justifyMode": "center" },
      "fieldConfig": { "defaults": { "unit": "short",
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "red", "value": null },
          { "color": "yellow", "value": 10 },
          { "color": "green", "value": 15 }
        ]}}}
    },
    {
      "id": 53, "type": "alertlist", "title": "📋 Alertas ativos (detalhe)",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 1 },
      "options": {
        "viewMode": "list",
        "groupMode": "default",
        "showInstances": false,
        "maxItems": 20,
        "sortOrder": 3,
        "stateFilter": {
          "firing": true, "pending": true, "noData": false, "normal": false, "error": true
        },
        "alertInstanceLabelFilter": "",
        "alertName": "",
        "dashboardAlerts": false,
        "folder": { "title": "Argus AI" }
      }
    },
    {
      "id": 1, "type": "gauge", "title": "CPU",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 5 },
      "timeFrom": "5m",
      "hideTimeOverride": true,
      "targets": [{ "datasource": { "uid": "prometheus-argus" }, "refId": "A",
        "expr": "100 - (avg(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 70 },
          { "color": "red", "value": 85 }
        ]}}}
    },
    {
      "id": 2, "type": "gauge", "title": "RAM",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 5 },
      "timeFrom": "5m",
      "hideTimeOverride": true,
      "targets": [{ "datasource": { "uid": "prometheus-argus" }, "refId": "A",
        "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 75 },
          { "color": "red", "value": 90 }
        ]}}}
    },
    {
      "id": 3, "type": "gauge", "title": "Disco Fotos",
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 5 },
      "timeFrom": "5m",
      "hideTimeOverride": true,
      "targets": [{ "datasource": { "uid": "prometheus-argus" }, "refId": "A",
        "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/mnt/fotos\"} / node_filesystem_size_bytes{mountpoint=\"/mnt/fotos\"} * 100)" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 70 },
          { "color": "red", "value": 80 }
        ]}}}
    },
    {
      "id": 5, "type": "gauge", "title": "Latência p95",
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 5 },
      "timeFrom": "15m",
      "hideTimeOverride": true,
      "targets": [{ "datasource": { "uid": "prometheus-argus" }, "refId": "A",
        "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_highr_seconds_bucket[5m])) by (le))" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0, "max": 5,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 0.5 },
          { "color": "red", "value": 2 }
        ]}}}
    },
    {
      "id": 4, "type": "gauge", "title": "Requests/s",
      "gridPos": { "h": 6, "w": 4, "x": 16, "y": 5 },
      "timeFrom": "15m",
      "hideTimeOverride": true,
      "targets": [{ "datasource": { "uid": "prometheus-argus" }, "refId": "A",
        "expr": "sum(irate(http_requests_total[1m]))" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0, "max": 10,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 2.5 },
          { "color": "red", "value": 5 }
        ]}}}
    },
    {
      "id": 10, "type": "row", "title": "Infraestrutura",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "collapsed": false
    },
    {
      "id": 11, "type": "timeseries", "title": "CPU ao longo do tempo",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [{ "datasource": { "uid": "prometheus-argus" }, "refId": "A",
        "legendFormat": "CPU %",
        "expr": "100 - (avg(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100,
        "color": { "mode": "fixed", "fixedColor": "blue" },
        "custom": { "fillOpacity": 15, "lineWidth": 2 },
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 70 },
          { "color": "red", "value": 85 }
        ]}}}
    },
    {
      "id": 12, "type": "timeseries", "title": "RAM ao longo do tempo",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "datasource": { "uid": "prometheus-argus" }, "refId": "A",
          "legendFormat": "RAM usada",
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes" },
        { "datasource": { "uid": "prometheus-argus" }, "refId": "B",
          "legendFormat": "RAM total",
          "expr": "node_memory_MemTotal_bytes" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "min": 0,
        "custom": { "fillOpacity": 10, "lineWidth": 2 }}}
    },
    {
      "id": 20, "type": "row", "title": "API",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "collapsed": false
    },
    {
      "id": 21, "type": "timeseries", "title": "Requests por minuto",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "targets": [
        { "datasource": { "uid": "prometheus-argus" }, "refId": "A",
          "legendFormat": "Total req/min",
          "expr": "sum(rate(http_requests_total[1m])) * 60" },
        { "datasource": { "uid": "prometheus-argus" }, "refId": "B",
          "legendFormat": "Erros 5xx/min",
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[1m])) * 60" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0,
        "custom": { "fillOpacity": 10, "lineWidth": 2 }}}
    },
    {
      "id": 22, "type": "timeseries", "title": "Latência por endpoint (p95)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "targets": [{ "datasource": { "uid": "prometheus-argus" }, "refId": "A",
        "legendFormat": "{{ handler }}",
        "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (handler, le)) > 0.01" }],
      "fieldConfig": { "defaults": { "unit": "s", "min": 0,
        "custom": { "fillOpacity": 0, "lineWidth": 2 }}}
    },
    {
      "id": 40, "type": "row", "title": "Banco e Fila",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "collapsed": false
    },
    {
      "id": 41, "type": "stat", "title": "Conexões PostgreSQL",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 30 },
      "targets": [{ "datasource": { "uid": "prometheus-argus" }, "refId": "A",
        "expr": "sum(pg_stat_activity_count{datname=\"argus_db\"})" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background",
        "graphMode": "none", "orientation": "auto", "textMode": "auto", "justifyMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "short",
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 70 },
          { "color": "red", "value": 90 }
        ]}}}
    },
    {
      "id": 42, "type": "stat", "title": "Comandos Redis/s",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 30 },
      "targets": [{ "datasource": { "uid": "prometheus-argus" }, "refId": "A",
        "expr": "rate(redis_commands_processed_total[5m])" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value",
        "graphMode": "area", "orientation": "auto", "textMode": "auto", "justifyMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "ops", "min": 0,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }
        ]}}}
    },
    {
      "id": 43, "type": "timeseries", "title": "Crescimento do disco de fotos",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "targets": [
        { "datasource": { "uid": "prometheus-argus" }, "refId": "A",
          "legendFormat": "Usado",
          "expr": "node_filesystem_size_bytes{mountpoint=\"/mnt/fotos\"} - node_filesystem_avail_bytes{mountpoint=\"/mnt/fotos\"}" },
        { "datasource": { "uid": "prometheus-argus" }, "refId": "B",
          "legendFormat": "Total",
          "expr": "node_filesystem_size_bytes{mountpoint=\"/mnt/fotos\"}" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "min": 0,
        "custom": { "fillOpacity": 10, "lineWidth": 2 }}}
    }
  ],
  "version": 2
}

# ══════════════════════════════════
# ARGUS AI — Variáveis de Produção
# ══════════════════════════════════
# Copie este arquivo para .env.production e preencha os valores reais.
# NUNCA commite .env.production no repositório!

# ══════════════════════════════════
# APP
# ══════════════════════════════════
DEBUG=false

# ══════════════════════════════════
# DATABASE (PostgreSQL — configurado no docker-compose)
# ══════════════════════════════════
# Dono do schema (roda migrations como argus). Usado pelo container Postgres.
DB_USER=argus
DB_PASSWORD=TROCAR-SENHA-FORTE-AQUI
DB_NAME=argus_db
# Papel de runtime DML-only (argus_app) — a API/worker conectam por aqui.
# Provisione com scripts/create_app_role.sql (ver docs/runbook-argus-app-role.md).
APP_DB_USER=argus_app
APP_DB_PASSWORD=TROCAR-SENHA-FORTE-APP
# DATABASE_URL (runtime, argus_app) é montada pelo docker-compose a partir de APP_DB_*.
# Migrations rodam como dono via MIGRATION_DATABASE_URL (effective_migration_url):
MIGRATION_DATABASE_URL=postgresql://argus:TROCAR-SENHA-FORTE-AQUI@db:5432/argus_db

# ══════════════════════════════════
# REDIS (configurado no docker-compose)
# ══════════════════════════════════
# Obrigatório em produção (o compose recusa subir sem). Gerar: openssl rand -hex 24
REDIS_PASSWORD=TROCAR-SENHA-FORTE-REDIS
# REDIS_URL é montada automaticamente pelo docker-compose

# ══════════════════════════════════
# AUTH
# ══════════════════════════════════
# Gerar com: openssl rand -hex 32
SECRET_KEY=TROCAR-GERAR-COM-OPENSSL-RAND-HEX-32
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=30

# ══════════════════════════════════
# ENCRYPTION (LGPD)
# ══════════════════════════════════
# Gerar com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=TROCAR-GERAR-COM-FERNET

# ══════════════════════════════════
# STORAGE — Cloudflare R2
# ══════════════════════════════════
# 1. Acesse: https://dash.cloudflare.com → R2 → Create bucket → nome: argus
# 2. Em R2 → Manage R2 API Tokens → Create API Token (Object Read & Write)
# 3. Copie o Account ID na página inicial do R2
S3_ENDPOINT=https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com
S3_ACCESS_KEY=SEU_R2_ACCESS_KEY
S3_SECRET_KEY=SEU_R2_SECRET_KEY
S3_BUCKET=argus

# ══════════════════════════════════
# LLM (LEGADO — recursos de geração/RAG descontinuados; settings mantidos só
# por compatibilidade. Pode deixar em branco/omitir.)
# ══════════════════════════════════
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=deepseek-r1:8b

# ══════════════════════════════════
# EMBEDDINGS
# ══════════════════════════════════
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSIONS=384
EMBEDDING_CACHE_TTL=3600

# ══════════════════════════════════
# FACE RECOGNITION
# ══════════════════════════════════
FACE_SIMILARITY_THRESHOLD=0.6

# ══════════════════════════════════
# GEOCODING
# ══════════════════════════════════
GEOCODING_PROVIDER=nominatim
GOOGLE_MAPS_API_KEY=

# ══════════════════════════════════
# RATE LIMITING
# ══════════════════════════════════
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_HEAVY=10/minute

# ══════════════════════════════════
# CORS (ajustar para seu domínio)
# ══════════════════════════════════
CORS_ORIGINS=["https://seu-dominio.com"]

# ══════════════════════════════════
# LGPD
# ══════════════════════════════════
DATA_RETENTION_DAYS=1825

# ══════════════════════════════════
# DOMÍNIO / TLS (Caddy)
# ══════════════════════════════════
DOMAIN=seu-dominio.com

# ══════════════════════════════════
# MONITORING (Grafana — obrigatório ao subir o stack de monitoramento)
# ══════════════════════════════════
GF_ADMIN_USER=admin
# Gerar: openssl rand -hex 24
GF_ADMIN_PASSWORD=TROCAR-SENHA-FORTE-GRAFANA

# ══════════════════════════════════
# NOTIFICAÇÕES (Telegram — alertas e relatório diário)
# ══════════════════════════════════
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

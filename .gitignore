# ══════════════════════════════════
# ARGUS AI — .gitignore
# ══════════════════════════════════

# ══════════════════════════════════
# SEGURANÇA — NUNCA commitar
# ══════════════════════════════════
.env
.env.local
.env.production
.env.staging
.env.bak.*
*.pem
*.key
*.crt
encryption.key
Chave SSH/
.secrets/

# ══════════════════════════════════
# PYTHON
# ══════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
*.whl
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.venv/
venv/
ENV/
env/

# ══════════════════════════════════
# TESTES E COVERAGE
# ══════════════════════════════════
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.pytest_cache/
.mypy_cache/

# ══════════════════════════════════
# IDEs E EDITORES
# ══════════════════════════════════
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/extensions.json

# PyCharm / JetBrains
.idea/

# Vim
*.swp
*.swo
*~

# Sublime Text
*.sublime-workspace
*.sublime-project

# ══════════════════════════════════
# OS
# ══════════════════════════════════
.DS_Store
Thumbs.db
Desktop.ini
*.bak
*.tmp
*.temp

# ══════════════════════════════════
# DOCKER
# ══════════════════════════════════
# Volumes locais de dados (nunca versionar dados do banco)
pgdata/
redisdata/
miniodata/

# ══════════════════════════════════
# MODELOS DE ML (pesados demais para git)
# ══════════════════════════════════
*.onnx
*.pt
*.pth
*.bin
*.h5
*.safetensors
models/
!app/models/
.cache/
sentence-transformers/
insightface/
torch_cache/

# Hugging Face cache
~/.cache/huggingface/
.cache/huggingface/

# ══════════════════════════════════
# STORAGE LOCAL (uploads e arquivos)
# ══════════════════════════════════
uploads/
downloads/
temp/
tmp/
*.pdf
*.jpg
*.jpeg
*.png
*.gif
*.bmp
!frontend/icons/*.png
!frontend/images/*.png
!frontend/images/*.jpg
!frontend/images/*.webp
!frontend/vendor/images/*.png

# ══════════════════════════════════
# ALEMBIC
# ══════════════════════════════════
# NÃO ignorar migrations — elas SÃO versionadas
# Apenas ignorar o cache do alembic
alembic/__pycache__/

# ══════════════════════════════════
# LOGS
# ══════════════════════════════════
*.log
logs/

# ══════════════════════════════════
# NODE (caso use build tools no frontend)
# ══════════════════════════════════
node_modules/
package-lock.json
yarn.lock

# ══════════════════════════════════
# JUPYTER (caso use notebooks para análise)
# ══════════════════════════════════
.ipynb_checkpoints/
*.ipynb

# ══════════════════════════════════
# RUFF / LINT
# ══════════════════════════════════
.ruff_cache/

# ══════════════════════════════════
# CLAUDE CODE & AI SKILLS
# ══════════════════════════════════
# Setup local — nunca commitar
CLAUDE.md
GEMINI.md
.claude/
.gemini/

# Credenciais e chaves privadas
Claude Flare - Argus.txt
.worktrees/

# NOTE: Skills (.claude/skills/ e .gemini/skills/) são mantidas localmente
# Não são versionadas — cada máquina tem sua cópia
# (MEU_GUIA_DE_ESTUDOS.md foi movido para docs/ e agora É versionado, p/ onboarding)

# ══════════════════════════════════
# PLANOS DE IMPLEMENTAÇÃO
# ══════════════════════════════════
# Artefatos de trabalho — não fazem parte do código
docs/plans/
docs/manual/

# Dados locais do monitoramento (make monitoring-local)
.monitoring-data/

# Worktrees isoladas (using-git-worktrees skill)
.worktrees/

# ══════════════════════════════════
# VÍDEOS DE TUTORIAL/DEMO (gerados localmente, não versionar)
# ══════════════════════════════════
.scratch/tutorial-video/

# Metadados do Windows (Mark of the Web) em arquivos copiados pro WSL
*:Zone.Identifier

arguseye.duckdns.org {
	header {
		X-Content-Type-Options "nosniff"
		# SAMEORIGIN permite embed futuro do Grafana via iframe na mesma origem
		X-Frame-Options "SAMEORIGIN"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(self)"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		-Server
	}

	# Bloqueia acesso externo ao endpoint de métricas do Prometheus
	# (Prometheus scrapa internamente via Docker network, não precisa ser público)
	respond /metrics 403

	# Dashboard Grafana — acessível em /grafana
	handle /grafana* {
		reverse_proxy grafana:3000
	}

	# /storage/* é roteado pela API (valida JWT antes de proxy ao MinIO).
	# NUNCA expor MinIO diretamente — bucket contém biométricos e PDFs sigilosos.
	reverse_proxy api:8000
}

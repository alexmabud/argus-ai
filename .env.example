# ══════════════════════════════════
# APP
# ══════════════════════════════════
DEBUG=true

# ══════════════════════════════════
# DATABASE
# ══════════════════════════════════
# Runtime da aplicação (papel DML-only em produção)
DATABASE_URL=postgresql://argus_app:CHANGE_ME@localhost:5432/argus_db
# Migrations (papel dono — só usado por alembic). Em dev pode ficar vazio.
MIGRATION_DATABASE_URL=postgresql://argus:CHANGE_ME@localhost:5432/argus_db
APP_DB_USER=argus_app
APP_DB_PASSWORD=CHANGE_ME

# ══════════════════════════════════
# REDIS
# ══════════════════════════════════
REDIS_URL=redis://localhost:6379

# ══════════════════════════════════
# AUTH
# ══════════════════════════════════
SECRET_KEY=gerar-chave-segura-com-openssl-rand-hex-32
# Chave separada para HMAC de busca de CPF (LGPD). Se vazia, usa SECRET_KEY como fallback.
# Recomendado: gerar separada com `openssl rand -hex 32` para reduzir blast radius.
CPF_HMAC_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=30
# TTL em horas para senha provisória gerada pelo admin (NULL = sem expiração)
SENHA_PROVISORIA_EXPIRE_HOURS=24
# Bloqueio de brute-force por IP (Redis)
MAX_LOGIN_ATTEMPTS=10
LOGIN_BLOCK_DURATION_SECONDS=3600

# ══════════════════════════════════
# ENCRYPTION (LGPD)
# ══════════════════════════════════
ENCRYPTION_KEY=gerar-com-scripts/generate_encryption_key.py

# ══════════════════════════════════
# STORAGE (MinIO local / Cloudflare R2 em prod)
# ══════════════════════════════════
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=argus
# URL pública do storage acessível pelo browser.
# Em produção, OBRIGATÓRIO definir com o endereço externo do MinIO/R2.
# Ex: S3_PUBLIC_URL=http://arguseye.duckdns.org:9000  (MinIO exposto na VM)
#     S3_PUBLIC_URL=https://pub-xxx.r2.dev             (Cloudflare R2 público)
# No Docker Compose local, o padrão http://localhost:9000 funciona se o browser
# estiver na mesma máquina que o servidor.
S3_PUBLIC_URL=http://localhost:9000

# ══════════════════════════════════
# LLM
# ══════════════════════════════════
LLM_PROVIDER=ollama
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:8b

# ══════════════════════════════════
# EMBEDDINGS
# ══════════════════════════════════
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSIONS=384
EMBEDDING_CACHE_TTL=3600

# ══════════════════════════════════
# FACE RECOGNITION
# ══════════════════════════════════
FACE_SIMILARITY_THRESHOLD=0.6

# ══════════════════════════════════
# GEOCODING
# ══════════════════════════════════
GEOCODING_PROVIDER=nominatim
GOOGLE_MAPS_API_KEY=

# ══════════════════════════════════
# RATE LIMITING
# ══════════════════════════════════
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_HEAVY=10/minute

# ══════════════════════════════════
# CORS
# ══════════════════════════════════
CORS_ORIGINS=["http://localhost:8000","http://localhost:3000"]

# ══════════════════════════════════
# LGPD
# ══════════════════════════════════
DATA_RETENTION_DAYS=1825

# ══════════════════════════════════
# MONITORAMENTO
# ══════════════════════════════════
# Bot Telegram: crie em https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=7123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Chat ID do GRUPO "Argus — Monitoramento" (começa com -100)
# Passos: criar grupo → adicionar bot → /getUpdates → pegar "id" do chat
TELEGRAM_CHAT_ID=-1001234567890

# Grafana: senha do usuário admin
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=troque_esta_senha_em_producao
